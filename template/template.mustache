<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {{^cancelled}}
        {{#subject}}
            <meta property="og:title" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} — {{subject}}" />
            {{^time_except}}
            <meta name="og:description" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} {{fa.default_time}} — {{fa.about}} {{subject}} {{fa.presented_by}} {{speaker}}" />
            {{/time_except}}
            {{#time_except}}
            <meta name="og:description" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} {{fa.just_this_week}} {{time_except}} — {{fa.about}} {{subject}} {{fa.presented_by}} {{speaker}}" />
            {{/time_except}}
        {{/subject}}
        {{^subject}}
            <meta property="og:title" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} — بحث آزاد" />
            {{^time_except}}
            <meta name="og:description" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} {{fa.default_time}} — بحث آزاد" />
            {{/time_except}}
            {{#time_except}}
            <meta name="og:description" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} {{fa.just_this_week}} {{time_except}} — بحث آزاد" />
            {{/time_except}}
        {{/subject}}
    {{/cancelled}}
    {{#cancelled}}
        <meta property="og:title" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} {{fa.cancelled}}" />
        <meta name="og:description" content="{{fa.meeting}} #{{count}} {{fa.pcworms}} {{fa.cancelled}}" />
    {{/cancelled}}

    <meta property="og:url" content="https://meet.pcworms.ir" />
    <meta property="og:image" content="./preview.png" />
    <title>دورهمی‌های کرم‌های کامپیوتر</title>

    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu+Mono:wght@700&family=Vazirmatn:wght@400;700;900&display=swap" rel="stylesheet">

    {{^cancelled}}
    <script>
        var sessionDate = new Date("{{date}}").getTime();
        var isFinished  = {{#finished}}true{{/finished}}{{^finished}}false{{/finished}};

        function toFa(s) {
            return String(s).replace(/\d/g, function(d) { return '۰۱۲۳۴۵۶۷۸۹'[d]; });
        }

        function formatCountdown(sec) {
            var d = Math.floor(sec / 86400);
            var h = Math.floor((sec % 86400) / 3600);
            var m = Math.floor((sec % 3600) / 60);
            var s = sec % 60;
            var parts = [];
            if (d > 0) parts.push(d + ' روز');
            if (h > 0) parts.push(h + ' ساعت');
            if (m > 0) parts.push(m + ' دقیقه');
            if (d === 0 && h === 0 && m === 0) parts.push(s + ' ثانیه');
            return toFa(parts.join(' و ')) + ' دیگر';
        }

        function formatElapsed(sec) {
            var h = Math.floor(sec / 3600);
            var m = Math.floor((sec % 3600) / 60);
            var s = sec % 60;
            var str = h > 0 ? h + ':' : '';
            str += (h > 0 ? String(m).padStart(2,'0') : m) + ':' + String(s).padStart(2,'0');
            return toFa(str);
        }

        function setPillState(state, text) {
            var pill = document.getElementById('countdown-pill');
            pill.className = 'countdown-pill state-' + state;
            document.getElementById('countdown-text').textContent = text;
        }

        function tick() {
            if (isFinished) {
                setPillState('ended', 'خاتمه یافت');
                return;
            }
            var now      = Date.now();
            var distance = sessionDate - now;
            if (distance > 0) {
                setPillState('before', formatCountdown(Math.floor(distance / 1000)));
            } else {
                var elapsed = Math.floor((now - sessionDate) / 1000);
                setPillState('live', formatElapsed(elapsed) + ' — در حال برگزاری');
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            tick();
            setInterval(tick, 1000);
        });
    </script>
    {{/cancelled}}
</head>

<body>
    {{#cancelled}}
    <div class="cancelled-overlay">
        <div class="cancelled-badge">لغو شد</div>
    </div>
    {{/cancelled}}

    <div class="page-center">

        <div class="site-header">
            <img class="site-logo" src="./assets/meeting-logo.png" alt="لوگو کرم‌های کامپیوتر">
            <div class="session-number">#{{count}}</div>
        </div>

        <h1 class="site-title">دورهمی‌های کرم‌های کامپیوتر</h1>

        {{^time_except}}
        <p class="site-time">هر جمعه ساعت ۱۸</p>
        {{/time_except}}
        {{#time_except}}
        <p class="site-time">⚠️ {{fa.just_this_week}} {{time_except}}</p>
        {{/time_except}}

        {{^cancelled}}
        <div class="countdown-pill state-before" id="countdown-pill">
            <div class="countdown-dot"></div>
            <span id="countdown-text">در حال محاسبه...</span>
        </div>
        {{/cancelled}}

        {{#subject}}
        <div class="speaker-card">
            <img class="speaker-profile" src="{{profile}}" alt="{{speaker}}">
            <div class="speaker-info">
                <div class="speaker-label">این هفته با</div>
                <div class="speaker-subject">{{subject}}</div>
                <div class="speaker-name">{{speaker}}</div>
            </div>
        </div>
        {{/subject}}

        {{^subject}}
        <div class="free-badge">این هفته: بحث آزاد</div>
        {{/subject}}

        <div class="divider"></div>

        <a class="tg-link" href="https://pcworms.ir/pcworms-chatrooms/">
            لینک جلسه در گروه تلگرام اعلام خواهد شد
        </a>

    </div>
</body>

</html>
